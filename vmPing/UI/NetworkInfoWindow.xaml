<Window x:Class="vmPing.UI.NetworkInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        UseLayoutRounding="True"
        Title="vmPing - My Network Info"
        Width="620"
        SizeToContent="Height"
        MaxHeight="680"
        MinHeight="200"
        MinWidth="480"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterOwner"
        Background="#e1e1e1"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style x:Key="AdapterCard" TargetType="Border">
            <Setter Property="Background" Value="#fbfbfb"/>
            <Setter Property="BorderBrush" Value="#202020"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#222"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="RowLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#444"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="132"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="RowValue" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#101010"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="CopyBtn" TargetType="Button">
            <Setter Property="Background" Value="WhiteSmoke"/>
            <Setter Property="BorderBrush" Value="#303030"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#ffffff"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#101010"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#cccccc"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AdapterName" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1a1a1a"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True" Margin="15">
        <TextBlock DockPanel.Dock="Top"
                   Style="{StaticResource ResourceKey=OptionHeaderTextStyle}"
                   Margin="0,5,0,10"
                   Text="My Network Info"/>

        <Grid DockPanel.Dock="Bottom" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Foreground="#666"
                       FontSize="11"
                       Text="Local adapter details and current public IP"/>

            <Button x:Name="RefreshButton"
                    Grid.Column="1"
                    Content="Refresh"
                    Width="88"
                    Margin="0,0,8,0"
                    Click="RefreshButton_Click"
                    Style="{StaticResource ButtonStandardStyle}"
                    Background="WhiteSmoke"
                    Foreground="Black"/>

            <Button Grid.Column="2"
                    Content="Close"
                    Width="75"
                    IsCancel="True"
                    Click="CloseButton_Click"
                    Style="{StaticResource ButtonStandardStyle}"
                    Background="WhiteSmoke"
                    Foreground="Black"/>
        </Grid>

        <Border BorderBrush="Black"
                BorderThickness="1"
                Background="#f3f3f3">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="MainPanel"
                            Margin="14,12,14,12"/>
            </ScrollViewer>
        </Border>
    </DockPanel>
</Window>
