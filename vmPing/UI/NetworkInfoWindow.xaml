<Window x:Class="vmPing.UI.NetworkInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="My Network Info - vmPing"
        Width="560"
        SizeToContent="Height"
        MaxHeight="680"
        MinHeight="200"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterOwner"
        Background="White"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- Adapter card border style -->
        <Style x:Key="AdapterCard" TargetType="Border">
            <Setter Property="Background"          Value="#f8f9fa"/>
            <Setter Property="BorderBrush"         Value="#d0d0d0"/>
            <Setter Property="BorderThickness"     Value="1"/>
            <Setter Property="CornerRadius"        Value="3"/>
            <Setter Property="Padding"             Value="12,10"/>
            <Setter Property="Margin"              Value="0,0,0,10"/>
        </Style>

        <!-- Section header label -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontFamily"    Value="Segoe UI"/>
            <Setter Property="FontSize"      Value="13"/>
            <Setter Property="FontWeight"    Value="SemiBold"/>
            <Setter Property="Foreground"    Value="#4040c0"/>
            <Setter Property="Margin"        Value="0,0,0,6"/>
        </Style>

        <!-- Row label (left column) -->
        <Style x:Key="RowLabel" TargetType="TextBlock">
            <Setter Property="FontFamily"    Value="Segoe UI"/>
            <Setter Property="FontSize"      Value="12"/>
            <Setter Property="Foreground"    Value="#505050"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width"         Value="130"/>
        </Style>

        <!-- Row value (right column) -->
        <Style x:Key="RowValue" TargetType="TextBlock">
            <Setter Property="FontFamily"    Value="Consolas"/>
            <Setter Property="FontSize"      Value="12"/>
            <Setter Property="Foreground"    Value="#202020"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping"  Value="Wrap"/>
        </Style>

        <!-- Copy button -->
        <Style x:Key="CopyBtn" TargetType="Button">
            <Setter Property="Background"    Value="Transparent"/>
            <Setter Property="BorderBrush"   Value="#b0b0b0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"       Value="5,2"/>
            <Setter Property="FontSize"      Value="11"/>
            <Setter Property="FontFamily"    Value="Segoe UI"/>
            <Setter Property="Foreground"    Value="#505050"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="Margin"        Value="6,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#e8e8e8"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#707070"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#d0d0d0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Adapter name heading -->
        <Style x:Key="AdapterName" TargetType="TextBlock">
            <Setter Property="FontFamily"    Value="Segoe UI"/>
            <Setter Property="FontSize"      Value="13"/>
            <Setter Property="FontWeight"    Value="SemiBold"/>
            <Setter Property="Foreground"    Value="#1a1a1a"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <DockPanel Background="White">

        <!-- ── Blue header bar ─────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Background="#1a73a7"
                Padding="18,13">
            <StackPanel Orientation="Horizontal">
                <Image Source="{StaticResource icon.info-circle}"
                       Width="22" Height="22"
                       Margin="0,0,10,0"
                       VerticalAlignment="Center"/>
                <TextBlock Text="My Network Info"
                           Foreground="White"
                           FontSize="17"
                           FontWeight="SemiBold"
                           FontFamily="Segoe UI"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ── Footer buttons ──────────────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom"
                Background="#f0f0f0"
                BorderBrush="#d0d0d0"
                BorderThickness="0,1,0,0"
                Padding="14,8">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="RefreshButton"
                        Content="↻  Refresh"
                        Width="88" Height="27"
                        Margin="0,0,8,0"
                        FontFamily="Segoe UI"
                        FontSize="12"
                        Click="RefreshButton_Click"/>
                <Button Content="Close"
                        Width="75" Height="27"
                        FontFamily="Segoe UI"
                        FontSize="12"
                        IsCancel="True"
                        Click="CloseButton_Click"/>
            </StackPanel>
        </Border>

        <!-- ── Scrollable content ──────────────────────────────────────── -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="MainPanel"
                        Margin="16,14,16,14"/>
        </ScrollViewer>

    </DockPanel>
</Window>
